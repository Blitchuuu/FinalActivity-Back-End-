# Server Configuration
PORT=5001

# MongoDB Connection
# Option 1: Local MongoDB
# MONGO_URI=mongodb://localhost:27017/clonetube

# Option 2: MongoDB Atlas (Cloud - Recommended)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/clonetube

# Generate a secure JWT_SECRET using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_your_own_secure_key_using_command_above
